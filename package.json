{
  "name": "ccdb-factor-mcp-server",
  "version": "1.0.0",
  "description": "CCDB碳排放因子搜索 MCP Server - 支持 Streamable HTTP 和 stdio 双传输机制",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:stdio": "node dist/index.js --stdio",
    "start:http": "node dist/index.js --http",
    "dev": "tsx src/index.ts --http",
    "dev:stdio": "tsx src/index.ts --stdio"
  },
  "keywords": [
    "mcp",
    "ccdb",
    "carbon",
    "emission-factor",
    "lca"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "express": "^4.21.0",
    "node-fetch": "^3.3.2",
    "zod": "^3.23.8",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/cors": "^2.8.17",
    "@types/crypto-js": "^4.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
